{
  "name": "@ingradient/ui",
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/storybook-smoke-consumer"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./brand": "./lib/brand.js",
    "./legacy": "./lib/legacy.js",
    "./tokens.css": "./lib/tokens.css",
    "./tokens": "./lib/tokens.js",
    "./primitives": "./lib/primitives.js",
    "./components": "./lib/components.js",
    "./patterns": "./lib/patterns.js"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "npm run storybook",
    "dev:smoke-consumer": "npm run dev --workspace apps/storybook-smoke-consumer",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "validate:storybook": "npm run test-storybook && npm run build:storybook && npm run test:visual",
    "validate:consumer-smoke": "npm run build:package && npm run build:smoke-consumer",
    "build": "npm run build:package && npm run build:docs",
    "build:smoke-consumer": "npm run build --workspace apps/storybook-smoke-consumer",
    "build:package": "rimraf lib && tsup --config tsup.config.ts && node scripts/copy-assets.mjs && node scripts/generate-tokens-css.mjs",
    "build:docs": "npm run build:storybook",
    "check:style-literals": "node scripts/check-style-literals.mjs",
    "check:doc-coverage": "node scripts/check-doc-coverage.mjs",
    "lint": "eslint src/",
    "test:unit": "vitest run",
    "test-storybook": "vitest run --config vitest.storybook.config.ts",
    "test:visual": "playwright test -c playwright.storybook.config.ts",
    "test:visual:update": "playwright test -c playwright.storybook.config.ts --update-snapshots",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:lib": "tsup --watch src --config tsup.config.ts"
  },
  "dependencies": {
    "@ingradient/ui": "file:ingradient-ui-0.0.1.tgz",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "react-day-picker": "^9.14.0",
    "recharts": "^3.7.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/browser-playwright": "^4.1.4",
    "axe-core": "^4.11.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "msw": "^2.13.4",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.59.1",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.5",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.1"
  }
}
